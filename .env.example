# Fraud Intelligence Platform - Environment Configuration
# Copy this file to .env and update values for your environment

# ===========================================
# Application Settings
# ===========================================
APP_NAME=Fraud Intelligence Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ===========================================
# API Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# Performance Targets
# ===========================================
TARGET_LATENCY_MS=150
MAX_BATCH_SIZE=100

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fraud_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===========================================
# Cache (Redis)
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20
CACHE_TTL_SECONDS=300
USER_PROFILE_TTL_SECONDS=3600

# ===========================================
# ML Model
# ===========================================
MODEL_PATH=models/fraud_model_v1
MODEL_VERSION=v1.0.0

# ===========================================
# Fraud Thresholds
# ===========================================
THRESHOLD_LOW=0.3
THRESHOLD_MEDIUM=0.6
THRESHOLD_HIGH=0.85

# ===========================================
# Security
# ===========================================
API_KEY_HEADER=X-API-Key
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ===========================================
# Monitoring
# ===========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
